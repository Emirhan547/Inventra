@using Inventra.WebUI.Dtos.WarehouseDtos
@model List<ResultWarehouseDto>

<div class="page-header">

    <div>

        <h2>Depolar</h2>

        <p class="text-muted">
            Depo yönetimi
        </p>

    </div>

    <a asp-action="Create"
       class="btn btn-primary">

        Yeni Depo

    </a>

</div>

<div class="content-card">

    <table class="table table-hover">

        <thead>

            <tr>

                <th>Depo Adı</th>

                <th>Lokasyon</th>

                <th width="180">
                    İşlemler
                </th>

            </tr>

        </thead>

        <tbody>

            @foreach (var item in Model)
            {
                <tr>

                    <td>@item.Name</td>

                    <td>@item.Location</td>

                    <td>

                        <a asp-action="Update"
                           asp-route-id="@item.Id"
                           class="btn btn-sm btn-warning">

                            Düzenle

                        </a>

                        <a asp-action="Delete"
                           asp-route-id="@item.Id"
                           class="btn btn-sm btn-danger">

                            Sil

                        </a>

                    </td>

                </tr>
            }

        </tbody>

    </table>

</div>