@using Inventra.WebUI.Dtos.WarehouseDtos
@model UpdateWarehouseDto

<div class="content-card">

    <h2 class="mb-4">
        Depo Güncelle
    </h2>

    <form asp-action="Update">

        <input asp-for="Id"
               type="hidden" />

        <div class="mb-3">

            <label>Depo Adı</label>

            <input asp-for="Name"
                   class="form-control" />

        </div>

        <div class="mb-3">

            <label>Lokasyon</label>

            <input asp-for="Location"
                   class="form-control" />

        </div>

        <button class="btn btn-primary">

            Güncelle

        </button>

    </form>

</div>