@{
    ViewData["Title"] =
        "Siparişi Tamamla";
}

<div class="content-card">

    <h2 class="mb-4">

        Siparişi Tamamla

    </h2>

    <p class="text-muted">

        Sipariş teslim alındığında
        ürünler seçilen depoya
        aktarılacaktır.

    </p>

    <form asp-action="Complete"
          method="post">

        <input type="hidden"
               name="id"
               value="@ViewBag.OrderId" />

        <div class="mb-3">

            <label class="form-label">

                Depo

            </label>

            <select name="warehouseId"
                    asp-items="ViewBag.Warehouses"
                    class="form-select">

                <option value="">

                    Depo Seçiniz

                </option>

            </select>

        </div>

        <button type="submit"
                class="btn btn-success">

            Teslim Al ve Stoğa İşle

        </button>

    </form>

</div>