@using Inventra.WebUI.Dtos.PurchaseOrders
@model CreatePurchaseOrderDto

<div class="content-card">

    <div class="mb-4">

        <h2>Yeni Satın Alma Siparişi</h2>

        <p class="text-muted">
            Tedarikçiye yeni satın alma siparişi oluşturun.
        </p>

    </div>

    <form asp-action="Create"
          method="post">

        <div class="mb-3">

            <label class="form-label">
                Tedarikçi
            </label>

            <select asp-for="SupplierId"
                    asp-items="ViewBag.Suppliers"
                    class="form-select">

                <option value="">
                    Tedarikçi Seçiniz
                </option>

            </select>

        </div>

        <div class="mb-3">

            <label class="form-label">
                Ürün
            </label>

            <select asp-for="ProductId"
                    asp-items="ViewBag.Products"
                    class="form-select">

                <option value="">
                    Ürün Seçiniz
                </option>

            </select>

        </div>

        <div class="mb-3">

            <label class="form-label">
                Miktar
            </label>

            <input asp-for="Quantity"
                   class="form-control" />

        </div>

        <div class="mb-3">

            <label class="form-label">
                Birim Fiyat
            </label>

            <input asp-for="UnitPrice"
                   class="form-control" />

        </div>

        <div class="d-flex gap-2">

            <button type="submit"
                    class="btn btn-primary">

                Sipariş Oluştur

            </button>

            <a asp-action="Index"
               class="btn btn-secondary">

                Vazgeç

            </a>

        </div>

    </form>

</div>