@using Inventra.WebUI.Dtos.PurchaseOrders
@model PurchaseOrderDetailDto

<div class="content-card">

    <h2>
        @Model.OrderNumber
    </h2>

    <hr />

    <div class="row">

        <div class="col-md-4">

            <strong>Tedarikçi</strong>

            <br />

            @Model.SupplierName

        </div>

        <div class="col-md-4">

            <strong>Toplam Tutar</strong>

            <br />

            @Model.TotalAmount.ToString("C")

        </div>

        <div class="col-md-4">

            <strong>Oluşturulma Tarihi</strong>

            <br />

            @Model.CreatedDate
            .ToString("dd.MM.yyyy HH:mm")

        </div>

    </div>

</div>

<br />

<div class="content-card">

    <h4>Sipariş Kalemleri</h4>

    <table class="table">

        <thead>

            <tr>

                <th>Ürün</th>

                <th>Miktar</th>

                <th>Birim Fiyat</th>

                <th>Tutar</th>

            </tr>

        </thead>

        <tbody>

            @foreach (var item in Model.Items)
            {
                <tr>

                    <td>
                        @item.ProductName
                    </td>

                    <td>
                        @item.Quantity
                    </td>

                    <td>
                        @item.UnitPrice.ToString("C")
                    </td>

                    <td>
                        @((item.Quantity * item.UnitPrice)
                            .ToString("C"))
                    </td>

                </tr>
            }

        </tbody>

    </table>

</div>