@using Inventra.WebUI.Dtos.PurchaseOrders

@model List<ResultPurchaseOrderDto>

<div class="page-header">

    <div>

        <h2>Satın Alma Siparişleri</h2>

        <p class="text-muted">
            Oluşturulan tüm siparişler
        </p>

    </div>

    <a asp-action="Create"
       class="btn btn-primary">

        Yeni Sipariş

    </a>

</div>

<div class="content-card">

    <table class="table table-hover align-middle">

        <thead>

            <tr>

                <th>Sipariş No</th>

                <th>Tedarikçi</th>

                <th>Tutar</th>

                <th>Durum</th>

                <th>Tarih</th>

                <th width="260">
                    İşlemler
                </th>

            </tr>

        </thead>

        <tbody>

            @foreach (var item in Model)
            {
                <tr>

                    <td>
                        @item.OrderNumber
                    </td>

                    <td>
                        @item.SupplierName
                    </td>

                    <td>
                        @item.TotalAmount.ToString("C")
                    </td>

                    <td>

                        @switch (item.Status)
                        {
                            case PurchaseOrderStatus.Pending:

                                <span class="badge bg-warning">
                                    Pending
                                </span>
                                break;

                            case PurchaseOrderStatus.Approved:

                                <span class="badge bg-primary">
                                    Approved
                                </span>
                                break;

                            case PurchaseOrderStatus.Completed:

                                <span class="badge bg-success">
                                    Completed
                                </span>
                                break;

                            case PurchaseOrderStatus.Cancelled:

                                <span class="badge bg-danger">
                                    Cancelled
                                </span>
                                break;
                        }

                    </td>

                    <td>
                        @item.CreatedDate.ToString("dd.MM.yyyy HH:mm")
                    </td>

                    <td>

                        <a asp-action="Details"
                           asp-route-id="@item.Id"
                           class="btn btn-sm btn-info">

                            Detay

                        </a>

                        @if (item.Status ==
                             PurchaseOrderStatus.Pending)
                        {
                            <a asp-action="Approve"
                               asp-route-id="@item.Id"
                               class="btn btn-sm btn-success">

                                Onayla

                            </a>
                        }

                    </td>

                </tr>
            }

        </tbody>

    </table>

</div>