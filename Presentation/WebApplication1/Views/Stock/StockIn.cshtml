@using Inventra.WebUI.Dtos.StockDtos
@model CreateStockInDto

<div class="content-card">

    <h2 class="mb-4">

        Stok Girişi

    </h2>

    <form asp-action="StockIn">

        <div class="mb-3">

            <label>
                Ürün
            </label>

            <select asp-for="ProductId"
                    asp-items="ViewBag.Products"
                    class="form-select">

                <option value="">
                    Ürün Seçiniz
                </option>

            </select>

        </div>

        <div class="mb-3">

            <label>
                Depo
            </label>

            <select asp-for="WarehouseId"
                    asp-items="ViewBag.Warehouses"
                    class="form-select">

                <option value="">
                    Depo Seçiniz
                </option>

            </select>

        </div>

        <div class="mb-3">

            <label>
                Miktar
            </label>

            <input asp-for="Quantity"
                   class="form-control" />

        </div>

        <div class="mb-3">

            <label>
                Açıklama
            </label>

            <textarea asp-for="Description"
                      class="form-control">
            </textarea>

        </div>

        <button class="btn btn-success">

            Stoğa Ekle

        </button>

    </form>

</div>