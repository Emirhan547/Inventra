@using Inventra.WebUI.Dtos.ProductDtos
@model List<ResultProductDto>

<div class="page-header">

    <div>

        <h2>Ürünler</h2>

        <p class="text-muted">
            Ürün yönetimi
        </p>

    </div>

    <a asp-action="Create"
       class="btn btn-primary">

        Yeni Ürün

    </a>

</div>

<div class="content-card">

    <table class="table table-hover">

        <thead>

            <tr>

                <th>Kategori</th>

                <th>Ürün</th>

                <th>SKU</th>

                <th>Fiyat</th>

                <th>Min. Stok</th>

                <th width="180">
                    İşlemler
                </th>

            </tr>

        </thead>

        <tbody>

            @foreach (var item in Model)
            {
                <tr>

                    <td>
                        @item.CategoryName
                    </td>

                    <td>
                        @item.Name
                    </td>

                    <td>
                        @item.SKU
                    </td>

                    <td>
                        @item.UnitPrice.ToString("C")
                    </td>

                    <td>
                        @item.MinimumStockLevel
                    </td>

                    <td>

                        <a asp-action="Update"
                           asp-route-id="@item.Id"
                           class="btn btn-sm btn-warning">

                            Düzenle

                        </a>

                        <a asp-action="Delete"
                           asp-route-id="@item.Id"
                           class="btn btn-sm btn-danger">

                            Sil

                        </a>

                    </td>

                </tr>
            }

        </tbody>

    </table>

</div>