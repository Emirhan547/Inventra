@using Inventra.WebUI.Dtos.SupplierDtos
@model UpdateSupplierDto

<div class="content-card">

    <h2 class="mb-4">
        Tedarikçi Güncelle
    </h2>

    <form asp-action="Update">

        <input asp-for="Id"
               type="hidden" />

        <div class="mb-3">

            <label>Firma Adı</label>

            <input asp-for="Name"
                   class="form-control" />

        </div>

        <div class="mb-3">

            <label>Telefon</label>

            <input asp-for="Phone"
                   class="form-control" />

        </div>

        <div class="mb-3">

            <label>Email</label>

            <input asp-for="Email"
                   class="form-control" />

        </div>

        <button class="btn btn-primary">

            Güncelle

        </button>

    </form>

</div>