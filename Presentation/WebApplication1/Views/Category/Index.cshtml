@using Inventra.WebUI.Dtos.CategoryDtos
@model List<ResultCategoryDto>

@{
    ViewData["Title"] = "Kategoriler";
}

<div class="page-header">

    <div>

        <h2>Kategoriler</h2>

        <p class="text-muted">
            Kategori yönetimi
        </p>

    </div>

    <a asp-controller="Category"
       asp-action="Create"
       class="btn btn-primary">

        Yeni Kategori

    </a>

</div>

<div class="content-card">

    <table class="table table-hover align-middle">

        <thead>

            <tr>

                <th>Kategori Adı</th>

                <th width="180">
                    İşlemler
                </th>

            </tr>

        </thead>

        <tbody>

            @if (Model.Any())
            {
                @foreach (var item in Model)
                {
                    <tr>

                        <td>
                            @item.Name
                        </td>

                        <td>

                            <a asp-controller="Category"
                               asp-action="Update"
                               asp-route-id="@item.Id"
                               class="btn btn-sm btn-warning">

                                Düzenle

                            </a>

                            <a asp-controller="Category"
                               asp-action="Delete"
                               asp-route-id="@item.Id"
                               class="btn btn-sm btn-danger">

                                Sil

                            </a>

                        </td>

                    </tr>
                }
            }
            else
            {
                <tr>

                    <td colspan="2"
                        class="text-center">

                        Kayıt bulunamadı

                    </td>

                </tr>
            }

        </tbody>

    </table>

</div>