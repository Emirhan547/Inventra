@using Inventra.WebUI.Dtos.CategoryDtos
@model UpdateCategoryDto

@{
    ViewData["Title"] = "Kategori Güncelle";
}

<div class="content-card">

    <div class="mb-4">

        <h2>Kategori Güncelle</h2>

        <p class="text-muted">
            Kategori bilgilerini güncelleyin.
        </p>

    </div>

    <form asp-action="Update"
          method="post">

        <input asp-for="Id"
               type="hidden" />

        <div class="mb-3">

            <label asp-for="Name"
                   class="form-label">

                Kategori Adı

            </label>

            <input asp-for="Name"
                   class="form-control" />

            <span asp-validation-for="Name"
                  class="text-danger">
            </span>

        </div>

        <div class="d-flex gap-2">

            <button type="submit"
                    class="btn btn-primary">

                Güncelle

            </button>

            <a asp-action="Index"
               class="btn btn-secondary">

                Vazgeç

            </a>

        </div>

    </form>

</div>